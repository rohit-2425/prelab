<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>PAN Card Online Application Form</title>
<style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    fieldset { margin-bottom: 15px; padding: 15px; border: 1px solid #ccc; }
    legend { font-weight: bold; color: #0056b3; }
    label { display: inline-block; width: 150px; margin-bottom: 10px; }
    input[type=text], input[type=email], select { width: 250px; padding: 5px; }
    input[type=radio], input[type=checkbox] { margin-right: 10px; }
    .form-group { margin-bottom: 10px; }
</style>
</head>
<body bgcolor="IVORY">

<h2>PAN Card Service Online Form</h2>

<form action="/submit-pan" method="post">

    <!-- Fieldset for Personal Details -->
    <fieldset>
        <legend>Personal Details</legend>
        <div class="form-group">
            <label>Title:</label>
            <input type="radio" name="title" value="mr" checked> Mr.
            <input type="radio" name="title" value="ms"> Ms./Mrs.
        </div>
        <div class="form-group">
            <label for="fname">First Name:</label>
            <input type="text" id="fname" name="fname" required>
        </div>
        <div class="form-group">
            <label for="dob">Date of Birth:</label>
            <input type="date" id="dob" name="dob" required>
        </div>
    </fieldset>

    <!-- Fieldset for Contact Information -->
    <fieldset>
        <legend>Contact Information</legend>
        <div class="form-group">
            <label for="email">Email Address:</label>
            <input type="email" id="email" name="email" required>
        </div>
        <div class="form-group">
            <label for="city">City:</label>
            <select id="city" name="city">
                <option value="mumbai">Mumbai</option>
                <option value="delhi">Delhi</option>
                <option value="bangalore">Bangalore</option>
                <option value="other">Other</option>
            </select>
        </div>
    </fieldset>

    <!-- Fieldset for Documents -->
    <fieldset>
        <legend>Documents Submitted (Checkboxes)</legend>
        <input type="checkbox" id="doc1" name="doc_aadhaar" value="aadhaar" checked>
        <label for="doc1" style="width: auto;">Aadhaar Card</label><br>
        <input type="checkbox" id="doc2" name="doc_voter" value="voterid">
        <label for="doc2" style="width: auto;">Voter ID</label><br>
        <input type="checkbox" id="doc3" name="doc_passport" value="passport">
        <label for="doc3" style="width: auto;">Passport</label>
    </fieldset>

    <button type="submit">Submit Application</button>
</form>

</body>
</html>
